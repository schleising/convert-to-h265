#!/bin/bash
set -euo pipefail

SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_SOURCE" ]; do
    SOURCE_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"
    SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
    case "$SCRIPT_SOURCE" in
        /*) ;;
        *) SCRIPT_SOURCE="$SOURCE_DIR/$SCRIPT_SOURCE" ;;
    esac
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"
# shellcheck source=common.sh
source "$SCRIPT_DIR/common.sh"

load_install_state

if [ ! -f "$PLIST_DEST" ]; then
    echo "Converter plist not found at $PLIST_DEST. Run install_converter_service.sh first." >&2
    exit 1
fi

if service_is_loaded; then
    launchctl kickstart -k "$(launchctl_target)"
else
    launchctl bootstrap "$(launchctl_domain)" "$PLIST_DEST"
fi

echo "Converter service started."